@model DiamondQuranWeb.Models.FavoritesViewModel
@using DiamondQuranWeb.Models
@using DiamondQuranWeb.SearchEngine.Enums
@using DiamondQuranWeb.Helpers
@{
    var data = new ApplicationDbContext();
}

@{
    ViewBag.Title = "Favorites";
}

<hr />
<div class="row align-items-center">
    <p class="col-12 mb-0 counterResultParagraph" style="width:100%; text-align:center">
        @Model.ListName
    </p>
</div>
<hr />
@foreach (var favorite in Model.Favorites)
{
    var item = data.Quran.Single(x => x.ID == favorite.Quran.ID);

    var ayahId = $"{item.ID}";
    var commentvisibility = item.HasComment ? "visible" : "hidden";
    <div id="block-@(favorite.ID)">
        <div class="row">
            <div class="col-1">
                <div style="height:100%; display:flex;flex-direction:column;justify-content:space-between;">
                    <i class="far fa-star" style="display:flex; justify-content:center; margin-bottom:0.5em;visibility:hidden"></i>
                    <i id="comment-@(ayahId)" class="fas fa-comments" style="display:flex; justify-content:center;margin-bottom:0.5em;visibility:@(commentvisibility)"></i>
                    <p style="width:100%;text-align:center; line-height:1; font-size:1rem; margin:0;padding:0">
                        <span>@item.SurahName</span>
                        <br>
                        <span>@item.AyahNumber</span>
                    </p>
                </div>
            </div>
            <div class="col-11">
                <p id="@(ayahId)">

                    @item.NormalEnhanced
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-6">
                <div style="display:flex; justify-content:center">
                    <button type="button" class="btn btn-light buttonsShadow" data-toggle="collapse" href="#options-@(ayahId)" role="button" aria-expanded="false" aria-controls="options-@(ayahId)" onclick="this.blur();">الخيارات</button>
                </div>
                <div class="collapse" id="options-@(ayahId)">
                    <div class="" style="display:flex; justify-content:center; width:100%">
                        @using (Ajax.BeginForm("GetTafsir", "Home", new { ayahId }, new AjaxOptions() { HttpMethod = "get", OnSuccess = "getTafsir" }, null))
                        {
                            <button type="submit" data-toggle="modal" data-target="#tafsirModal" class="tafsir btn btn-light buttonsShadow" style="margin:0.5em;">تفسير</button>
                        }
                        @using (Ajax.BeginForm("RemoveFavorite", "Home", new { favoriteId = favorite.ID, favoriteListId = favorite.FavoriteList.ID }, new AjaxOptions() { HttpMethod = "post", OnSuccess = "removeFavorite" }, null))
                        {

                            <button type="submit" class="btn btn-light buttonsShadow" id="removeFavBtn-@(favorite.ID)" onclick="removeFavoriteClicked('@(favorite.ID)')" style="margin:0.5em;display:inline-flex; align-items: center">
                                ازالة من المفضلة
                                <span id="removeFavSpinner-@(favorite.ID)" class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display:none"></span>
                            </button>
                        }
                        @using (Ajax.BeginForm("GetComment", "Home", new { ayahId }, new AjaxOptions() { HttpMethod = "get", OnSuccess = "getComment" }, null))
                        {
                            <button type="submit" data-toggle="modal" data-target="#commentModal" class="btn btn-light buttonsShadow" style="margin:0.5em;">تعليق</button>
                        }
                        <button name="@ayahId" type="button" class="copyBtn btn btn-light buttonsShadow" data-toggle="tooltip" data-placement="bottom" title="تم نسخ الآية" style="margin:0.5em;" onclick="copyToClipboard(this.name);">نسخ</button>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div style="display:flex; justify-content:center">
                    @Html.ActionLink("الذهاب للاية", "Quran", "Home", new { SurahNumber = item.SurahNumber, AyahNumber = item.AyahNumber }, new { @class = "btn btn-light buttonsShadow" })
                </div>
            </div>
        </div>
        <hr />
    </div>
}
<div class="modal fade" tabindex="-1" role="dialog" id="tafsirModal" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                @Html.EnumDropDownListFor(x => x.Tafsirs, null, new { id = "tafsir", @class = "form-control modal-title", style = "padding:0;width:auto", onchange = "changeTafsir(this.name,this.value)" })
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" style="position:relative;min-height:4rem;">
                <div id="spinner" class="spinner-border spinnerPopup" style="z-index:1; display:normal; margin: auto;position: absolute;top: 0; left: 0; bottom: 0; right: 0; width: 3rem; height: 3rem;" role="status" disabled>
                    <span class="sr-only">Loading...</span>
                </div>
                <div id="tafsirPopup">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" tabindex="-1" role="dialog" id="commentModal" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">تعليق</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="-body" style="position:relative;min-height:4rem;">
                <div id="spinner" class="spinner-border spinnerPopup" style="z-index:1; margin: auto;position: absolute;top: 0; left: 0; bottom: 0; right: 0; width: 3rem; height: 3rem;" role="status" disabled>
                    <span class="sr-only">Loading...</span>
                </div>
                <textarea id="commentText" style="width:100%;height:100%"></textarea>
            </div>
            <div class="modal-footer">
                <button type="submit" id="saveCommentBtn" class="btn btn-primary" onclick="saveComment(this.name);">Save changes</button>
                <button type="submit" id="deleteCommentBtn" class="btn btn-primary" onclick="deleteComment(this.name);">Delete</button>
                <button type="submit" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" tabindex="-1" role="dialog" id="favoritesModal" aria-labelledby="myLargeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">المفضلة</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" style="position:relative;min-height:4rem;">
                <div id="spinner" class="spinner-border spinnerPopup" style=" z-index:1; margin: auto;position: absolute;top: 0; left: 0; bottom: 0; right: 0; width: 3rem; height: 3rem;" role="status" disabled>
                    <span class="sr-only">Loading...</span>
                </div>
                <table class="display" id="example" style="width:100%"></table>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<style>
    .btn-disable {
        cursor: not-allowed;
        pointer-events: none;
        /*Button disabled - CSS color class*/
        color: #c0c0c0;
        background-color: #ffffff;
    }
</style>
@section Scripts{
    <script type="text/javascript" src="~/Scripts/versesListView.js"></script>
    <script>
        function removeFavorite(data) {
            alert(data.success);
            if (data.success) {
                $('#block-' + data.favoriteId).remove();
            } else {
                $('#removeFavSpinner-' + data.favoriteId).css('display', 'none');
                $('#removeFavBtn-' + data.favoriteId).removeClass('btn-disable');
            }
        }
        function removeFavoriteClicked(id) {
            $('#removeFavSpinner-' + id).css('display', 'inline-block');
            $('#removeFavBtn-' + id).addClass('btn-disable');
        }
    </script>
}